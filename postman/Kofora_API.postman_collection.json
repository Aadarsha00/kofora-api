{
  "info": {
    "_postman_id": "f08d7cb8-0c84-4ab1-b34d-14f9f5a00b11",
    "name": "Kofora API v1",
    "description": "Comprehensive Kofora ecommerce API collection with role-based auth, token automation, query mapping, and image upload/image_url ingestion examples.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const refreshPath = '/api/v1/auth/token/refresh/';",
          "const hasAuth = pm.request.auth && pm.request.auth.type === 'bearer';",
          "const currentUrl = pm.request.url.toString();",
          "if (!hasAuth || currentUrl.includes('/api/v1/auth/login/') || currentUrl.includes('/api/v1/auth/register/') || currentUrl.includes(refreshPath)) {",
          "  return;",
          "}",
          "const refreshToken = pm.environment.get('refresh_token');",
          "const expiry = Number(pm.environment.get('token_expiry_epoch') || '0');",
          "const now = Math.floor(Date.now() / 1000);",
          "if (!refreshToken) {",
          "  return;",
          "}",
          "if (expiry - now > 60) {",
          "  return;",
          "}",
          "pm.sendRequest({",
          "  url: pm.environment.get('baseUrl') + refreshPath,",
          "  method: 'POST',",
          "  header: {'Content-Type': 'application/json'},",
          "  body: { mode: 'raw', raw: JSON.stringify({ refresh: refreshToken }) }",
          "}, function (err, res) {",
          "  if (err || !res) return;",
          "  const json = res.json();",
          "  const data = json.data || json;",
          "  if (data.access) {",
          "    pm.environment.set('access_token', data.access);",
          "    pm.environment.set('token_expiry_epoch', (Math.floor(Date.now()/1000) + 14 * 60).toString());",
          "  }",
          "  if (data.refresh) {",
          "    pm.environment.set('refresh_token', data.refresh);",
          "  }",
          "});"
        ]
      }
    }
  ],
