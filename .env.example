# Core
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.kofora.com,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=https://kofora.com,https://www.kofora.com

# Database
DATABASE_URL=postgresql://kofora_user:kofora_password@127.0.0.1:5432/kofora_db

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/3

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=no-reply@kofora.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=Kofora <no-reply@kofora.com>

# JWT
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.kofora.com/api/v1/auth/google/callback/

# Payments
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYPAL_CLIENT_ID=paypal-client-id
PAYPAL_CLIENT_SECRET=paypal-client-secret
PAYPAL_MODE=live

# App
DEFAULT_CURRENCY=USD
SECONDARY_CURRENCY=CAD
FRONTEND_BASE_URL=https://kofora.com
ORDER_PAYMENT_RESERVATION_MINUTES=60
ORDER_EXPIRATION_SWEEP_MINUTES=10
